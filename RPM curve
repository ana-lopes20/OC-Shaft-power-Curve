<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Elfsquad Hz Graph</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1"></script>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    .chart-wrap {
      position: relative;
      height: 500px;
      width: 100%;
      background-color: #fff;
    }
  </style>
</head>
<body>
<div class="chart-wrap">
  <canvas id="myChart"></canvas>
</div>

<script>
let chart;

function initChart() {
  const ctx = document.getElementById('myChart').getContext('2d');
  chart = new Chart(ctx, {
    type: 'line',
    data: {
      datasets: [
        {
          label: 'OC [kg O₂/h]',
          data: [],
          yAxisID: 'yOC',
          borderColor: '#1f77b4',
          backgroundColor: '#1f77b4',
          borderWidth: 2,
          pointRadius: 0,
          tension: 0
        },
        {
          label: 'Aerator Shaft [kW]',
          data: [],
          yAxisID: 'yShaft',
          borderColor: '#c0392b',
          backgroundColor: '#c0392b',
          borderWidth: 2,
          pointRadius: 0,
          tension: 0
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      scales: {
        x: {
          type: 'linear',
          position: 'bottom',
          min: 30,
          max: 50,
          title: { display: true, text: 'Hz' },
          ticks: { stepSize: 2 },
          grid: { color: '#e0e0e0' }
        },
        yShaft: {
          type: 'linear',
          position: 'left',
          title: { display: true, text: 'Aerator Shaft [kW]', color: '#c0392b' },
          ticks: { color: '#c0392b' },
          grid: { color: '#e0e0e0' }
        },
        yOC: {
          type: 'linear',
          position: 'right',
          title: { display: true, text: 'Oxygenation Capacity [kg O₂/h]', color: '#1f77b4' },
          ticks: { color: '#1f77b4' },
          grid: { drawOnChartArea: false }
        }
      },
      plugins: {
        legend: { position: 'top' },
        annotation: {
          annotations: {
            designLine: {
              type: 'line',
              scaleID: 'x',
              value: 0,
              borderColor: '#7a8c1f',
              borderWidth: 2,
              label: {
                display: true,
                content: 'Design',
                position: 'start',
                backgroundColor: 'rgba(122,140,31,0.85)',
                color: '#fff'
              }
            },
            maxLine: {
              type: 'line',
              scaleID: 'x',
              value: 0,
              borderColor: '#000',
              borderWidth: 2,
              label: {
                display: true,
                content: 'Maximum',
                position: 'start',
                backgroundColor: 'rgba(0,0,0,0.85)',
                color: '#fff'
              }
            }
          }
        }
      }
    }
  });
}

let lastImageSig = null;
let lastSentText = null;

function toPoints(xs, ys) {
  return xs.map((x, i) => ({ x: Number(x), y: Number(ys[i]) }));
}

function mapData(config) {
  const values = config.values || {};

  // --- ADJUST THESE KEYS TO MATCH YOUR ELFSQUAD FEATURE CODES ---
  const hzList    = values['hz_list']    || [];   // array of Hz values, e.g. [30,31,...,50]
  const ocList    = values['oc_list']    || [];   // array of OC values matching hzList
  const shaftList = values['shaft_list'] || [];   // array of Shaft [kW] values matching hzList

  const design = Number(values['design_hz'] ?? 0);
  const max    = Number(values['max_hz']    ?? 0);

  return { hzList, ocList, shaftList, design, max };
}

function updateGraph(config) {
  const d = mapData(config);

  chart.data.datasets[0].data = toPoints(d.hzList, d.ocList);
  chart.data.datasets[1].data = toPoints(d.hzList, d.shaftList);

  // Auto-scale each y-axis independently
  const ocVals    = d.ocList.map(Number).filter(Number.isFinite);
  const shaftVals = d.shaftList.map(Number).filter(Number.isFinite);

  if (ocVals.length) {
    const mn = Math.min(...ocVals), mx = Math.max(...ocVals);
    const pad = (mx - mn) * 0.05 || 1;
    chart.options.scales.yOC.min = mn - pad;
    chart.options.scales.yOC.max = mx + pad;
  }
  if (shaftVals.length) {
    const mn = Math.min(...shaftVals), mx = Math.max(...shaftVals);
    const pad = (mx - mn) * 0.05 || 1;
    chart.options.scales.yShaft.min = mn - pad;
    chart.options.scales.yShaft.max = mx + pad;
  }

  const anns = chart.options.plugins.annotation.annotations;

  anns.designLine.value = d.design;
  anns.designLine.label = { ...anns.designLine.label, content: `Design: ${d.design} Hz` };

  anns.maxLine.value = d.max;
  anns.maxLine.label = { ...anns.maxLine.label, content: `Maximum: ${d.max} Hz` };

  chart.update('none');

  const sig = JSON.stringify(d);
  if (sig !== lastImageSig) {
    lastImageSig = sig;
    sendGraphImage();
  }
}

function sendGraphImage() {
  const dataUrl = chart.toBase64Image('image/png', 1);
  window.top.postMessage({
    name: 'elfsquad.updateImageValue',
    args: {
      nodeId: '7a40d8e6-a6cb-4ca1-3ef0-08ded1e03ef1',
      image: dataUrl,
    },
  }, '*');
}

window.addEventListener('message', function (e) {
  if (e.data && e.data.name === 'elfsquad.configurationUpdated') {
    console.log('Received configuration update:', e.data.args);
    updateGraph(e.data.args);

    const newText = 'text from the graph builder';
    if (newText !== lastSentText) {
      lastSentText = newText;
      window.top.postMessage({
        name: 'elfsquad.updateTextValue',
        args: {
          nodeId: 'cc62c043-899e-4b91-ab6d-08ded1293b42',
          textValue: newText,
        },
      }, '*');
    }
  }
});

Chart.register(window['chartjs-plugin-annotation']);
initChart();
updateGraph({});
</script>
</body>
</html>
